# Copy to .env.local for local development, and set the same variable in Vercel
# (Project → Settings → Environment Variables) for the deployed app.
#
# Shared password that gates the HQ / Admin views. The Sales Rep experience is
# open and does not require this. Authorised admin emails are configured in
# src/utils/auth.ts (ADMIN_EMAILS).
VITE_ADMIN_PASSWORD=change-me
